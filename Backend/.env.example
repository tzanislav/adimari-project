PORT=5001
NODE_ENV=development
DEV_MODE=development

MONGODB_URI=mongodb+srv://username:password@example.mongodb.net/database_name?retryWrites=true&w=majority
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_BUCKET_NAME=replace-me

OPENAI_API_KEY=replace-me
CLICKUP_API_KEY=replace-me

FIREBASE_SERVICE_ACCOUNT_PATH=./auth/account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}